<Window x:Class="UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Taxi dispatcher - Login page" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="NavajoWhite">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="10" 
                Padding="30" 
                Width="320"
                BorderBrush="DarkOliveGreen" 
                BorderThickness="2">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Welcome back" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>

                <TextBlock Text="Please, login to your account" 
                           FontSize="15"
                           Foreground="DarkSlateGray" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>

                <TextBlock Text="Login" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" 
                         VerticalContentAlignment="Center" 
                         Padding="5,0"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="UserPasswordBox" 
                             Height="35" 
                             VerticalContentAlignment="Center" 
                             Padding="5,0"
                             Margin="0,0,0,5"/>

                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="Red" 
                           FontSize="12" 
                           TextWrapping="Wrap"
                           Height="30"
                           Margin="0,5"/>

                <Button Content="Login" 
                        Command="{Binding LoginCommand}" 
                        CommandParameter="{Binding ElementName=UserPasswordBox}"
                        Height="40" 
                        Background="Yellow" 
                        Foreground="Black" 
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,10,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>