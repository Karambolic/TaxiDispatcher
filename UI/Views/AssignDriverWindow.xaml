<Window x:Class="UI.Views.AssignDriverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select driver" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select a free driver for this list:" Margin="0,0,0,10" FontWeight="Bold"/>

        <ListBox x:Name="DriversList" 
         Grid.Row="1" 
         ItemsSource="{Binding Drivers}"
         SelectedItem="{Binding SelectedDriver, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="{Binding FirstName}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding LastName}" Margin="5,0,0,0"/>
                        <TextBlock Text=" - "/>
                        <TextBlock Text="{Binding PhoneNumber}" FontStyle="Italic" Foreground="Gray"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Assign" Width="80" Click="Assign_Click" Margin="0,0,10,0" Background="Green" Foreground="White"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="Cancel_Click" Background="IndianRed"/>
        </StackPanel>
    </Grid>
</Window>