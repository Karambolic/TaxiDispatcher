<Window x:Class="UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Taxi dispatcher system - Orders management console" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="NavajoWhite">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="WhiteSmoke"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="AntiqueWhite"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="Yellow"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Crimson"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="15,0,0,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="DarkOliveGreen" Padding="15">
            <Grid>
                <TextBlock Text="TAXI FLEET MANAGER v1.0" Foreground="White" FontWeight="Bold" FontSize="20"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Welcome, " Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding DispatcherName}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="Log out" 
                            Style="{StaticResource LogoutButtonStyle}" 
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="GhostWhite">
            <StatusBarItem>
                <TextBlock Text="System ready" Foreground="Gray" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Connected to SQL server" Foreground="DarkGreen" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left" Width="240" Background="WhiteSmoke" BorderBrush="WhiteSmoke" BorderThickness="0,0,1,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="OPERATIONS" FontWeight="Bold" Foreground="DimGray" Margin="5,0,0,10" FontSize="12"/>
                    <Button Content="Create new order" Style="{StaticResource ActionButtonStyle}" Command="{Binding CreateOrderCommand}" Foreground="DarkOliveGreen"/>
                    <Button Content="Refresh active list" Style="{StaticResource SidebarButtonStyle}" Command="{Binding RefreshOrdersCommand}" Foreground="Blue"/>
                    <Button Content="Cancel selected" Style="{StaticResource SidebarButtonStyle}" Command="{Binding CancelOrderCommand}" Foreground="Crimson"/>

                    <Separator Margin="0,15"/>

                    <TextBlock Text="SQL REPORTS" FontWeight="Bold" Foreground="DarkOliveGreen" Margin="5,0,0,10" FontSize="12"/>
                    <Button Content="1 Drivers and their autos" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[1]}"/>
                    <Button Content="2 Clients with vodafone phone nums" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[2]}"/>
                    <Button Content="3 Orders by period" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[3]}"/>
                    <Button Content="4 Total clients count" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[4]}"/>
                    <Button Content="5 Tariff average price" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[5]}"/>
                    <Button Content="6 Most effective dispatcher" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[6]}"/>
                    <Button Content="7 Max checks per client" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[7]}"/>
                    <Button Content="8 Idle drivers" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[8]}"/>
                    <Button Content="9 Tariff usage status" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ReportCommands[9]}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <TabControl Margin="10" Background="Transparent" BorderThickness="0">
            <TabItem Header="Live dispatch board">
                <Grid Background="White">
                    <DataGrid ItemsSource="{Binding Orders}" 
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              AlternatingRowBackground="NavajoWhite">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="New">
                                        <Setter Property="Background" Value="#CCFFCC"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Canceled">
                                        <Setter Property="Background" Value="#FFCCCC"/>
                                        <Setter Property="Foreground" Value="DarkRed"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Client phone" Binding="{Binding Client.PhoneNumber}" Width="110"/>

                            <DataGridTextColumn Header="Pickup" Width="1.5*">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0}, {1}">
                                        <Binding Path="AddressStart.StreetName" />
                                        <Binding Path="AddressStart.StreetNumber" />
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Destination" Width="1.5*">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0}, {1}">
                                        <Binding Path="AddressEnd.StreetName" />
                                        <Binding Path="AddressEnd.StreetNumber" />
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Pax" Binding="{Binding PassengerCount}" Width="40">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Commentary" Binding="{Binding Comment}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Price" Binding="{Binding FinalPrice, StringFormat={}{0} UAH}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="SQL query results">
                <Border Background="White" Padding="15">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="FloralWhite" Padding="10" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Report date range:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0"/>

                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <DatePicker SelectedDate="{Binding StartDate}" Width="130"/>

                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                <DatePicker SelectedDate="{Binding EndDate}" Width="130"/>

                                <TextBlock Text="(Used for Query 6.3)" Foreground="Gray" FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <DataGrid ItemsSource="{Binding ReportData}" 
                                  AutoGenerateColumns="True" 
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  Background="White"
                                  AlternatingRowBackground="AliceBlue">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>